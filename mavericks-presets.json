{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "mavericks-native",
      "hidden": true,
      "displayName": "native -- build on OS X 10.9",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "MAVERICKS_EXPECTED_MODE": "native",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "10.9",
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      }
    },
    {
      "name": "mavericks-cross",
      "hidden": true,
      "displayName": "cross -- build for 10.9 on a modern host",
      "binaryDir": "${sourceDir}/build-cross",
      "cacheVariables": {
        "MAVERICKS_EXPECTED_MODE": "cross",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "10.9",
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      }
    }
  ]
}
